[scraper]
keywords = [
    "montre connectee",
    "smartwatch",
    "montre intelligente",
    "montre sport connectee",
    "montre connectee femme",
    "montre connectee homme",
    "huawei watch",
]
marketplace_url = "https://www.amazon.fr"
brand_filter    = "huawei"
pages           = 3
# chrome_executable = "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"
# (optional — auto-detected on macOS and Linux if not set)

[telegram]
chat_id = 0  # Your Telegram chat ID

[monitoring]
interval_minutes = 30
